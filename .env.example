# ======================
# SMS Dashboard 配置文件
# ======================

# ----- 基础配置 -----
DASHBOARD_HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=http://你的 NAS 内网 IP:8787

# ----- 登录认证 -----
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=请修改为你的后台登录密码

# ----- Webhook 配置（可选） -----
WEBHOOK_TOKEN=请生成随机 token
WEBHOOK_SIGNING_KEY=请生成随机签名密钥

# ----- 网络配置 -----
BIND_ADDRESS=0.0.0.0
PUBLIC_PORT=8787

# ----- 数据库配置 -----
DB_BACKEND=mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=sms_dashboard
MYSQL_USER=sms_dashboard
MYSQL_PASSWORD=请修改为你的 MySQL 用户密码
MYSQL_ROOT_PASSWORD=请修改为你的 MySQL root 密码
MYSQL_CHARSET=utf8mb4

# ----- Android SMS Gateway 配置 -----
# 手机和 NAS 需在同一局域网
SMS_GATEWAY_BASE_URL=http://手机 IP:8080
SMS_GATEWAY_USER=手机 App 显示的用户名
SMS_GATEWAY_PASSWORD=手机 App 显示的密码
POLL_SECONDS=8
POLL_LIMIT=80

# ----- 数据保留 -----
MESSAGE_RETENTION_DAYS=30

# ----- 闲管家配置（可选，不卖卡密可留空） -----
XGJ_APP_ID=
XGJ_APP_SECRET=
XGJ_MCH_ID=sms-dashboard
XGJ_MCH_SECRET=请生成随机商户密钥
